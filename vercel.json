{
  "crons": [
    {
      "path": "/api/cron/morning-brief",
      "schedule": "0 1 * * *"
    }
  ]
}

// คำว่า "0 1 * * *" หมายถึง นาทีที่ 0, ชั่วโมงที่ 1 ของเวลาสากล (UTC) ครับ
// เนื่องจากเวลาไทย (UTC+7) จะเร็วกว่าเวลาสากลอยู่ 7 ชั่วโมง ดังนั้น 01.00 UTC จะตรงกับเวลา 08.00 น. ของบ้านเราพอดีเป๊ะครับ!
